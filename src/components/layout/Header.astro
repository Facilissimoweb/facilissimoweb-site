---
const currentPath = Astro.url.pathname;
const nav = [
  { href: '/',           label: 'Home' },
  { href: '/chi-siamo',  label: 'Chi sono' },
  { href: '/servizi',    label: 'Servizi' },
  { href: '/portfolio',  label: 'Portfolio' },
  { href: '/contatti',   label: 'Contatti' },
];
---
<header class="fixed top-0 left-0 right-0 z-50
               bg-base/80 backdrop-blur-md border-b border-muted/50">
  <div class="flex items-center justify-between px-5 py-4 md:px-10">
    <a href="/" class="flex items-center gap-2 group">
      <span class="h-8 w-8 rounded-full bg-pop flex items-center justify-center
                   font-display text-base text-lg italic
                   group-hover:rotate-12 transition-transform duration-300">F</span>
      <span class="font-label text-sm font-bold uppercase tracking-wider text-ink">
        Facilissimo<span class="text-pop">.</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {nav.map(item => (
        <a href={item.href}
           class:list={[
             'font-label text-sm uppercase tracking-wider transition-colors',
             currentPath === item.href ? 'text-pop' : 'text-ink/70 hover:text-ink'
           ]}>
          {item.label}
        </a>
      ))}
      <a href="/contatti" class="btn-primary !py-2 !px-5 !text-xs">Parliamone</a>
    </nav>

    <button id="menu-toggle"
      class="md:hidden relative h-10 w-10 flex items-center justify-center z-[110]"
      aria-label="Apri menu" aria-expanded="false">
      <span class="h-0.5 w-6 bg-ink absolute transition-all duration-300 -translate-y-1.5" data-bar="top"></span>
      <span class="h-0.5 w-6 bg-ink absolute transition-all duration-300" data-bar="mid"></span>
      <span class="h-0.5 w-6 bg-ink absolute transition-all duration-300 translate-y-1.5" data-bar="bot"></span>
    </button>
  </div>

  <nav id="mobile-menu"
    class="md:hidden fixed inset-0 bg-[#FAF9F6] z-[100]
           flex flex-col items-center justify-center
           opacity-0 pointer-events-none transition-all duration-300">
    <div class="flex flex-col items-center gap-8 w-full max-w-xs text-center">
      {nav.map((item, i) => (
        <a href={item.href}
           class="font-display text-5xl text-ink w-full py-2
                  transform translate-y-4 opacity-0 transition-all duration-500"
           style={`transition-delay: ${i * 60}ms`}
           data-menu-link>
          {item.label}
        </a>
      ))}
      <a href="/contatti" class="btn-primary mt-4 w-full">Inizia il progetto</a>
    </div>
  </nav>
</header>

<script>
  function initHeader() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    const bars = toggle.querySelectorAll('[data-bar]');
    const links = menu.querySelectorAll('[data-menu-link]');
    let open = false;

    const setMenu = (state) => {
      open = state;
      toggle.setAttribute('aria-expanded', String(open));

      // Gestione menu
      menu.classList.toggle('opacity-0', !open);
      menu.classList.toggle('pointer-events-none', !open);

      // Icona Hamburger
      bars[0].classList.toggle('rotate-45', open);
      bars[0].classList.toggle('translate-y-0', open);
      bars[0].classList.toggle('-translate-y-1.5', !open);

      bars[1].classList.toggle('opacity-0', open);

      bars[2].classList.toggle('-rotate-45', open);
      bars[2].classList.toggle('translate-y-0', open);
      bars[2].classList.toggle('translate-y-1.5', !open);

      // Link animazione
      links.forEach(l => {
        l.classList.toggle('translate-y-0', open);
        l.classList.toggle('opacity-100', open);
      });

      // Blocca scroll body quando aperto
      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => setMenu(!open));

    // Chiudi menu al click sui link senza interferire con la navigazione
    links.forEach(l => {
      l.addEventListener('click', () => {
        // Un piccolo delay permette di percepire il click prima che inizi il caricamento
        setTimeout(() => setMenu(false), 150);
      });
    });

    // Chiudi se si preme ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) setMenu(false);
    });
  }

  // Inizializza
  initHeader();

  // Supporto per View Transitions di Astro
  document.addEventListener('astro:after-swap', initHeader);
</script>
